MONITOR_APP_NAME=Binance Account Monitor
MONITOR_API_HOST=127.0.0.1
MONITOR_API_PORT=8010
MONITOR_HISTORY_DB_PATH=data/monitor_history.db
MONITOR_REFRESH_INTERVAL_MS=600000
MONITOR_REFRESH_TIMEOUT_MS=60000
MONITOR_HISTORY_WINDOW_DAYS=7
MONITOR_ACCOUNT_CONCURRENCY=5
BINANCE_RECV_WINDOW_MS=5000
BINANCE_CORE_TIMEOUT_MS=4000
BINANCE_SECONDARY_TIMEOUT_MS=2500
BINANCE_CORE_RETRY_ATTEMPTS=5
BINANCE_SECONDARY_RETRY_ATTEMPTS=3
BINANCE_MANUAL_CORE_TIMEOUT_MS=2500
BINANCE_MANUAL_SECONDARY_TIMEOUT_MS=1500
BINANCE_MANUAL_CORE_RETRY_ATTEMPTS=2
BINANCE_MANUAL_SECONDARY_RETRY_ATTEMPTS=1

# Telegram secret refs (real values live in config/secrets.enc.json)
TG_ENABLED=false
TG_BOT_TOKEN_SECRET_REF=
TG_CHAT_ID_SECRET_REF=
TG_PROXY_URL=
TG_MAX_QUEUE_SIZE=50
TG_DRY_RUN=false

# Alerts / audit
UNI_MMR_ALERTS_ENABLED=false
UNIMMR_ALERT_EVENT_MAX_ROWS=2000
AUTH_AUDIT_MAX_ROWS=2000
ADMIN_IDLE_TIMEOUT_MINUTES=30
GUEST_IDLE_TIMEOUT_MINUTES=120

# Config locations
ACCESS_CONTROL_CONFIG_FILE=config/access_control.json
MONITOR_ACCOUNTS_FILE=config/binance_monitor_accounts.json
SECRETS_FILE=config/example-secrets.enc.json

# Secret master key (deployment step: create the key file first, then point this var to it)
MONITOR_MASTER_KEY=
MONITOR_MASTER_KEY_FILE=

# Optional Python override for maintenance scripts
MONITOR_PYTHON=
